/* ============================================================
   CAMPUS COMPANION TRADE - LUXURY ACADEMIC THEME
   Inspired by Institutional Prestige & Modern E-Commerce
   ============================================================ */

:root {
  /* Palette: Harvard Crimson & Ivory */
  --crimson: #A51C30;        /* Institutional Red */
  --crimson-dark: #7B1525;
  --crimson-light: #C14453;
  --ivory: #FBFBFB;          /* Pure, clean base */
  --cream: #F5F2ED;           /* Soft academic background */
  --gold: #B8860B;           /* Satin Gold */
  --gold-light: #D4AF37;
  --black: #1A1A1A;          /* Deep charcoal for text */
  --gray-text: #555555;
  --dove: #888888;
  --white: #FFFFFF;

  /* Typography */
  --font-display: 'Playfair Display', serif;    /* Elegant titles */
  --font-body: 'Crimson Pro', serif;              /* Academic reading */
  --font-accent: 'Bebas Neue', sans-serif;       /* Bold, loud headings */

  /* Effects */
  --shadow-soft: 0 10px 30px rgba(0,0,0,0.05);
  --shadow-medium: 0 15px 45px rgba(0,0,0,0.1);
  --shadow-crimson: 0 8px 20px rgba(165, 28, 48, 0.15);
  --transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.98);
  --glass: rgba(255, 255, 255, 0.8);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: var(--font-body);
  background-color: var(--ivory);
  color: var(--black);
  line-height: 1.6;
  overflow-x: hidden;
}

/* ===== UTILITIES ===== */
.hidden { display: none !important; }
.text-center { text-align: center; }
.bg-soft { background-color: var(--cream); }

/* ============================================================
   BUTTONS (Satin & Crimson)
   ============================================================ */
.btn {
  display: inline-block;
  padding: 12px 26px;
  border: none;
  border-radius: 2px; /* Sharper edges for professional look */
  cursor: pointer;
  font-family: var(--font-accent);
  font-size: 14px;
  letter-spacing: 1px;
  transition: var(--transition);
  text-decoration: none;
  text-transform: uppercase;
}

.btn-red {
  background: var(--crimson);
  color: var(--white);
  box-shadow: var(--shadow-crimson);
}
.btn-red:hover {
  background: var(--crimson-dark);
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(165, 28, 48, 0.3);
}

.btn-gold {
  background: var(--gold);
  color: var(--white);
}
.btn-gold:hover {
  background: var(--gold-light);
  transform: translateY(-2px);
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--dove);
  color: var(--gray-text);
}
.btn-outline:hover {
  border-color: var(--crimson);
  color: var(--crimson);
}
.btn-sm { padding: 6px 12px; font-size: 11px; }

/* ============================================================
   HEADER (Institutional White)
   ============================================================ */
#main-header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: var(--glass);
  backdrop-filter: blur(15px);
  border-bottom: 3px solid var(--crimson);
  padding: 0 40px;
  height: 75px;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 2px 15px rgba(0,0,0,0.05);
}

.header-logo {
  display: flex; align-items: center; gap: 15px;
  cursor: pointer;
}
.header-logo img { height: 55px; width: auto; }
.header-logo-text .name {
  font-family: var(--font-display); font-size: 22px; font-weight: 700;
  color: var(--crimson); line-height: 1;
}
.header-logo-text .tagline {
  font-family: var(--font-body); font-size: 13px; color: var(--gray-text);
  font-style: italic;
}

.header-nav { display: flex; align-items: center; gap: 10px; }
.nav-link {
  background: none; border: none; color: var(--black);
  font-family: var(--font-accent); font-size: 13px; letter-spacing: 1px;
  padding: 10px 15px; cursor: pointer;
  transition: var(--transition);
}
.nav-link:hover, .nav-link.active { color: var(--crimson); }

.welcome-msg {
  font-family: var(--font-body); font-size: 14px;
  color: var(--crimson); font-style: italic;
  padding: 6px 16px;
  border: 1px solid var(--crimson);
  border-radius: 20px;
  background: rgba(165, 28, 48, 0.05);
}

/* ============================================================
   HERO SECTION (Cinematic Luxury)
   ============================================================ */
.hero {
  position: relative; height: 85vh; min-height: 550px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; background: var(--black);
}
.hero-bg {
  position: absolute; inset: 0;
  background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
              url('https://images.unsplash.com/photo-1541339907198-e08756edd815?q=80&w=2070&auto=format&fit=crop');
  background-size: cover; background-position: center;
  transition: transform 10s linear;
}
.hero:hover .hero-bg { transform: scale(1.1); }

.hero-content {
  position: relative; z-index: 1; text-align: center; padding: 0 20px;
  animation: fadeInUp 1s ease-out;
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-eyebrow {
  font-family: var(--font-accent); font-size: 16px; letter-spacing: 5px;
  color: var(--gold-light); margin-bottom: 20px; text-transform: uppercase;
}
.hero-title {
  font-family: var(--font-display); font-size: clamp(40px, 8vw, 85px);
  font-weight: 900; line-height: 1.1; margin-bottom: 25px; color: var(--white);
}
.hero-title span { color: var(--gold-light); }
.hero-subtitle {
  font-size: clamp(16px, 2.5vw, 22px); color: rgba(255,255,255,0.8);
  max-width: 700px; margin: 0 auto 40px; line-height: 1.6; font-style: italic;
}

/* ============================================================
   MARKETPLACE (Boutique Style)
   ============================================================ */
.section { padding: 80px 40px; max-width: 1300px; margin: 0 auto; }
.section-title {
  font-family: var(--font-display); font-size: 36px; font-weight: 700;
  color: var(--black); margin-bottom: 10px;
}
.section-subtitle { color: var(--dove); font-size: 16px; margin-bottom: 40px; font-style: italic; }

.products-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 35px;
}

.product-card {
  background: var(--white);
  border: 1px solid rgba(0,0,0,0.05);
  border-radius: 0; /* Institutional look is often sharper */
  transition: var(--transition);
  display: flex; flex-direction: column;
  box-shadow: var(--shadow-soft);
}
.product-card:hover {
  transform: translateY(-10px);
  box-shadow: var(--shadow-medium);
  border-color: var(--crimson);
}

.product-img {
  height: 260px; background: var(--cream); position: relative; overflow: hidden;
}
.product-img img { width: 100%; height: 100%; object-fit: cover; transition: var(--transition); }
.product-card:hover .product-img img { transform: scale(1.08); }

.product-badge {
  position: absolute; top: 15px; right: 15px;
  background: var(--crimson); color: var(--white);
  font-family: var(--font-accent); font-size: 10px; letter-spacing: 1px;
  padding: 4px 10px; border-radius: 0;
}

.product-info { padding: 25px; text-align: center; }
.product-category-tag {
  font-size: 11px; color: var(--gold); font-family: var(--font-accent);
  letter-spacing: 2px; margin-bottom: 10px; text-transform: uppercase;
}
.product-name {
  font-family: var(--font-display); font-size: 20px; font-weight: 700;
  margin-bottom: 8px; color: var(--black);
}
.product-vendor { font-size: 13px; color: var(--dove); margin-bottom: 12px; font-style: italic; }
.product-desc { font-size: 14px; color: var(--gray-text); line-height: 1.6; margin-bottom: 20px; }
.product-price {
  font-family: var(--font-display); font-size: 26px; font-weight: 700;
  color: var(--crimson); margin-bottom: 20px;
}

/* ============================================================
LIVING VIEWS (Frosted Glass)
============================================================ */
.functional-view {
  position: fixed; inset: 0; background: var(--white); z-index: 2000;
  overflow-y: auto; padding: 85px 20px 40px;
}
.functional-view.hidden { display: none; }

/* Auth Container - The "Institutional Entry" */
.auth-container {
  display: grid; grid-template-columns: 1fr 1fr;
  width: 100%; max-width: 1000px; margin: 60px auto;
  background: var(--white);
  border: 1px solid rgba(0,0,0,0.1);
  border-radius: 0;
  box-shadow: var(--shadow-medium);
}
.auth-left { background: var(--crimson); color: var(--white); padding: 60px; }
.auth-right { background: var(--white); color: var(--black); padding: 60px; }

.auth-title {
  font-family: var(--font-display); font-size: 28px; font-weight: 700;
  margin-bottom: 10px; color: var(--white);
}
.auth-subtitle { font-style: italic; color: rgba(255,255,255,0.7); margin-bottom: 30px; }

.group { margin-bottom: 20px; }
.group label {
  display: block; font-family: var(--font-accent); font-size: 11px;
  color: var(--dove); margin-bottom: 8px; letter-spacing: 1px;
}
.group input, .group select {
  width: 100%; padding: 12px; border: 1px solid #ddd;
  font-family: var(--font-body); font-size: 16px; outline: none;
}
.group input:focus { border-color: var(--crimson); }

/* ============================================================
ADMIN & VENDOR (The Professional Suite)
============================================================ */
.admin-layout { display: grid; grid-template-columns: 280px 1fr; min-height: calc(100vh - 75px); }
.admin-sidebar {
  background: var(--black); color: var(--white);
  padding: 30px 0; position: sticky; top: 75px; height: calc(100vh - 75px);
}
.admin-sidebar-title {
  font-family: var(--font-accent); font-size: 12px; color: var(--gold);
  padding: 0 30px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px;
}
.admin-nav-item {
  display: flex; align-items: center; gap: 12px; padding: 14px 30px;
  cursor: pointer; transition: var(--transition); color: var(--dove-light);
  font-family: var(--font-body); font-size: 15px; border: none; background: none; width: 100%; text-align: left;
}
.admin-nav-item:hover { color: var(--white); background: rgba(255,255,255,0.05); }
.admin-nav-item.active { color: var(--white); background: var(--crimson); font-weight: 600; }

.admin-content { padding: 40px; background: var(--cream); color: var(--black); }
.panel { display: none; }
.panel.active { display: block; }
.page-title { font-family: var(--font-display); font-size: 32px; margin-bottom: 8px; color: var(--crimson); }
.page-sub { color: var(--dove); font-style: italic; margin-bottom: 30px; }

.stat-card {
  background: var(--white); border: 1px solid rgba(0,0,0,0.05);
  border-radius: 0; padding: 25px; transition: var(--transition);
  box-shadow: var(--shadow-soft);
}
.stat-card:hover { border-color: var(--crimson); transform: translateY(-5px); }
.stat-val { font-family: var(--font-display); font-size: 36px; color: var(--crimson); font-weight: 700; }
.stat-card h3 { font-size: 13px; color: var(--gray-text); font-family: var(--font-accent); text-transform: uppercase; }

/* ============================================================
FOOTER
============================================================ */
.site-footer {
  background: var(--black); color: var(--white); padding: 60px 40px;
  text-align: center; border-top: 4px solid var(--gold);
}
.footer-logo { height: 50px; margin-bottom: 20px; opacity: 0.9; }
.footer-links { display: flex; justify-content: center; gap: 30px; margin-bottom: 20px; }
.footer-link { color: var(--dove-light); text-decoration: none; font-size: 13px; transition: var(--transition); }
.footer-link:hover { color: var(--gold-light); }

/* Responsive */
@media (max-width: 900px) {
  .auth-container { grid-template-columns: 1fr; }
  .admin-layout { grid-template-columns: 1fr; }
  .admin-sidebar { position: relative; height: auto; }
}
